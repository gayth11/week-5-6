import pandas as pd
import numpy as np
from sklearn.feature_selection import VarianceThreshold
from sklearn.linear_model import LinearRegression
from sklearn.model_selection import train_test_split
df = pd.read_csv("data/day24_selection.csv")
X, y = df.iloc[:, :-1], df.iloc[:, -1]
X_train, X_test, y_train, y_test = train_test_split(X, y, random_state=42)
model = LinearRegression().fit(X_train, y_train)
print("R² before:", model.score(X_test, y_test))
var = VarianceThreshold(0.01)
X_train = var.fit_transform(X_train)
X_test = var.transform(X_test)
X_train = pd.DataFrame(X_train)
corr = X_train.corr().abs()
upper = corr.where(np.triu(np.ones(corr.shape), k=1).astype(bool))
drop = [c for c in upper.columns if any(upper[c] > 0.9)]
X_train = X_train.drop(columns=drop)
X_test = pd.DataFrame(X_test).drop(columns=drop)
model2 = LinearRegression().fit(X_train, y_train)
print("R² after:", model2.score(X_test, y_test))
